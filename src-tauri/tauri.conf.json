{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QSE Studio",
  "version": "0.2.0",
  "identifier": "fr.nicolashue.qsestudio",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "QSE Studio",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "",
    "frontendDist": "../web-client/out"
  },
  "plugins": {
    "sql": {
      "sqlite": ["qse_studio.db"]
    }
  }
}
